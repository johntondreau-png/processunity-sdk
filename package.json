{
  "name": "processunity-sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for the ProcessUnity TPRM API",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "processunity",
    "tprm",
    "third-party-risk",
    "vendor-management",
    "grc",
    "sdk"
  ],
  "author": "John Tondreau",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "msw": "^2.7.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
